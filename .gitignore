# Runtime config (generated by setup_mcp.cmd / setup_mcp.sh)
config.json
# Container-internal config (generated by ts.mjs on start; bind-mounted into container)
config.container.json

# ignore claude local settings
**/settings.local.json

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Node (win-watcher, vscode-codesearch)
node_modules/
*.vsix
vscode-codesearch/out/
vscode-codesearch/setup-out.txt
vscode-codesearch/src/buildInfo.ts

# Typesense data directory (when running locally outside Docker)
typesensedata/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
*.log

# Editor / OS
.vscode/settings.json
.idea/
*.suo
*.user
