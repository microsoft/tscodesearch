# Exclude development/local files from Docker build
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.git/
.gitignore
*.log
*.pid

# VS Code extension (separate project)
vscode-codesearch/

# Sample data — mounted as a volume during e2e tests, not baked into the image
sample/

# Tests — mounted as a volume at runtime so changes don't require a rebuild
tests/

# Local config files (contain secrets — never bake into the image)
config.json
config.container.json

# Documentation
*.md
!README.md
