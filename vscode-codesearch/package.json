{
  "name": "codesearch",
  "publisher": "local",
  "displayName": "TsCodeSearch",
  "description": "Real-time Typesense code search panel for C# monorepos",
  "version": "0.1.0",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tscodesearch",
          "title": "TsCodeSearch",
          "icon": "icons/codesearch.svg"
        }
      ]
    },
    "views": {
      "tscodesearch": [
        {
          "type": "webview",
          "id": "tscodesearch.panel",
          "name": "Search"
        },
        {
          "id": "tscodesearch.roots",
          "name": "Roots",
          "when": "true"
        }
      ]
    },
    "commands": [
      {
        "command": "tscodesearch.openPanel",
        "title": "TsCodeSearch: Open Panel",
        "icon": "$(search)"
      },
      {
        "command": "tscodesearch.setup",
        "title": "TsCodeSearch: Set Up",
        "icon": "$(rocket)"
      },
      {
        "command": "tscodesearch.addRoot",
        "title": "TsCodeSearch: Add Root",
        "icon": "$(add)"
      },
      {
        "command": "tscodesearch.removeRoot",
        "title": "TsCodeSearch: Remove Root",
        "icon": "$(remove)"
      },
      {
        "command": "tscodesearch.restartContainer",
        "title": "TsCodeSearch: Restart",
        "icon": "$(debug-restart)"
      },
      {
        "command": "tscodesearch.stopContainer",
        "title": "TsCodeSearch: Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "tscodesearch.reindex",
        "title": "TsCodeSearch: Re-index Root",
        "icon": "$(sync)"
      },
      {
        "command": "tscodesearch.refreshRoots",
        "title": "TsCodeSearch: Refresh",
        "icon": "$(refresh)"
      }
    ],
    "configuration": [
      {
        "title": "TsCodeSearch",
        "properties": {
          "tscodesearch.mode": {
            "type": "string",
            "enum": ["docker", "wsl"],
            "default": "docker",
            "description": "Backend mode: 'docker' runs the indexserver in a Docker container managed by the extension; 'wsl' manages the WSL indexserver (ts.sh) directly.",
            "enumDescriptions": [
              "Docker mode — extension builds and manages a Docker container.",
              "WSL mode — extension manages the WSL indexserver via ts.sh."
            ]
          },
          "tscodesearch.repoPath": {
            "type": "string",
            "default": "",
            "description": "Path to the tscodesearch repository root."
          },
          "tscodesearch.mcpPort": {
            "type": "number",
            "default": 3000,
            "description": "Port for the MCP SSE endpoint."
          },
          "tscodesearch.typesensePort": {
            "type": "number",
            "default": 8108,
            "description": "Port for the Typesense server."
          }
        }
      },
      {
        "title": "TsCodeSearch — WSL Mode",
        "when": "config.tscodesearch.mode == wsl",
        "properties": {
          "tscodesearch.configPath": {
            "type": "string",
            "default": "",
            "description": "Path to codesearch config.json. Roots, API key, and port are read from this file."
          }
        }
      },
      {
        "title": "TsCodeSearch — Docker Mode",
        "when": "config.tscodesearch.mode == docker",
        "properties": {
          "tscodesearch.roots": {
            "type": "object",
            "default": {},
            "description": "Named source roots to index. Keys are root names (e.g. \"default\"), values are Windows paths (e.g. \"C:\\\\myproject\\\\src\").",
            "additionalProperties": { "type": "string" }
          },
          "tscodesearch.dockerImage": {
            "type": "string",
            "default": "codesearch-mcp",
            "description": "Docker image name."
          },
          "tscodesearch.dockerContainer": {
            "type": "string",
            "default": "codesearch",
            "description": "Docker container name."
          }
        }
      }
    ],
    "keybindings": [
      {
        "command": "tscodesearch.openPanel",
        "key": "ctrl+shift+f1",
        "mac": "cmd+shift+f1"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "tscodesearch.openPanel" },
        { "command": "tscodesearch.setup" },
        { "command": "tscodesearch.addRoot" },
        { "command": "tscodesearch.removeRoot" },
        { "command": "tscodesearch.restartContainer" },
        { "command": "tscodesearch.stopContainer" },
        { "command": "tscodesearch.refreshRoots" }
      ],
      "view/title": [
        {
          "command": "tscodesearch.addRoot",
          "when": "view == tscodesearch.roots",
          "group": "navigation"
        },
        {
          "command": "tscodesearch.refreshRoots",
          "when": "view == tscodesearch.roots",
          "group": "navigation"
        },
        {
          "command": "tscodesearch.restartContainer",
          "when": "view == tscodesearch.roots",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tscodesearch.removeRoot",
          "when": "view == tscodesearch.roots && viewItem == root",
          "group": "inline"
        },
        {
          "command": "tscodesearch.reindex",
          "when": "view == tscodesearch.roots && viewItem == root",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "prebuild": "node -e \"var d=new Date();require('fs').writeFileSync('src/buildInfo.ts','export const BUILD_DATE = \\\"'+d.toISOString().slice(0,16).replace('T',' ')+' UTC\\\";\\n')\"",
    "precompile": "npm run prebuild",
    "prewatch": "npm run prebuild",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --require tsx/cjs --test src/test/client.test.ts src/test/pipeline.test.ts",
    "test:pipeline": "node --require tsx/cjs --test src/test/pipeline.test.ts",
    "package": "vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
